{
  "name": "telegram-profanity-filter",
  "version": "1.0.0",
  "description": "Telegram profanity filter",
  "main": "index.ts",
  "scripts": {
    "build": "npx tsc",
    "start": "npx tsc && node dist/index.js",
    "dev": "rm -rf ./dist && npx tsc && node dist/index.js",
    "test": "mocha --recursive --extension spec.ts --require ts-node/register $1",
    "nyc": "nyc mocha --recursive --extension spec.ts --require ts-node/register && nyc report --reporter=lcov",
    "cov": "nyc mocha --recursive --extension spec.ts --require ts-node/register && nyc report --reporter=lcov",
    "watch": "nodemon --exec 'npm run nyc' --ext ts,tsx",
    "deploy": "git push heroku main:master"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VadimCpp/telegram-profanity-filter.git"
  },
  "author": "Vadym Kaninskyi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/VadimCpp/telegram-profanity-filter"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "modern-ahocorasick": "^2.0.4",
    "node-telegram-bot-api": "^0.66.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^21.0.0",
    "mocha": "^11.3.0",
    "nyc": "^18.0.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.3",
    "ts-node": "^10.9.2"
  }
}
